# Required for LLM classification
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Telegram notifications
DENBUST_TELEGRAM_BOT_TOKEN=
DENBUST_TELEGRAM_CHAT_ID=

# Optional: Email report output (SMTP)
DENBUST_EMAIL_SMTP_HOST=
DENBUST_EMAIL_SMTP_PORT=587
DENBUST_EMAIL_SMTP_USERNAME=
DENBUST_EMAIL_SMTP_PASSWORD=
DENBUST_EMAIL_FROM=
DENBUST_EMAIL_TO=
DENBUST_EMAIL_USE_TLS=true
DENBUST_EMAIL_SUBJECT=

# Optional: Override persistence paths (useful for GitHub Actions + state repo mode)
DENBUST_STORE_PATH=
DENBUST_RUNS_DIR=
